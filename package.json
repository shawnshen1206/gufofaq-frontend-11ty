{
  "name": "gufofaq-frontend-11ty",
  "version": "0.1.0",
  "private": true,
  "description": "GufoFAQ react-friendly 11ty 切版交付專案",
  "scripts": {
    "dev": "run-p dev:html dev:css",
    "dev:html": "eleventy --serve",
    "dev:css": "sass --watch src/scss/main.scss:dist/css/main.css",
    "build:html": "eleventy",
    "build:css": "sass src/scss/main.scss:dist/css/main.css --style=compressed --no-source-map",
    "build": "run-s build:css build:html"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.83.0"
  }
}
